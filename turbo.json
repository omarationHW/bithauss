{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "env": [
        "NODE_ENV",
        "API_URL",
        "NEXT_PUBLIC_*",
        "AZURE_*",
        "SUPABASE_*",
        "FRONTEND_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {},
    "typecheck": {}
  }
}
